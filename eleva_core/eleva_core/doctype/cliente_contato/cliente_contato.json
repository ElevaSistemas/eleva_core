{
  "doctype": "DocType",
  "name": "Cliente Contato",
  "module": "Eleva Core",
  "istable": 1,
  "editable_grid": 1,
  "fields": [
    {
      "fieldname": "contact_type",
      "fieldtype": "Select",
      "label": "Tipo de Canal",
      "options": "Telefone
Celular
Email
WhatsApp",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "contact_value",
      "fieldtype": "Data",
      "label": "Valor",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "contact_name",
      "fieldtype": "Data",
      "label": "Nome do Contato",
      "in_list_view": 1
    },
    {
      "fieldname": "contact_role",
      "fieldtype": "Select",
      "label": "Tipo de Contato",
      "options": "Principal
Financeiro
Comercial
Operacional
Outro",
      "in_list_view": 1
    },
    {
      "fieldname": "is_primary",
      "fieldtype": "Check",
      "label": "Principal",
      "in_list_view": 1
    },
    {
      "fieldname": "is_verified",
      "fieldtype": "Check",
      "label": "Verificado",
      "in_list_view": 1
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Observação"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Sales User",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}
